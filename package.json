{
  "name": "n8n-nodes-kipps-whatsapp-agent",
  "version": "1.0.8",
  "description": "n8n node for sending WhatsApp template messages via Kipps.AI",
  "license": "MIT",
  "homepage": "https://kipps.ai",
  "keywords": [
    "n8n-community-node-package",
    "kipps",
    "whatsapp"
  ],
  "author": {
    "name": "kipps.ai",
    "email": "tech@kipps.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KIPPS-AI/n8n-node-kipps-whatsapp-agent.git"
  },
  "scripts": {
  "build": "tsc && cpx \"nodes/**/*.svg\" dist/nodes",
  "dev": "tsc --watch"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "displayName": "Kipps.AI WhatsApp Agent",
    "icon": "file:nodes/KippsAiWhatsappAgent/KippsAiWhatsappAgent.svg",
    "categories": [
      "Communication"
    ],
    "nodes": [
      "dist/nodes/KippsAiWhatsappAgent/KippsAiWhatsappAgent.node.js"
    ],
    "credentials": [
      "dist/credentials/KippsAiApi.credentials.js"
    ]
  },
  "main": "dist/index.js",
  "bugs": {
    "url": "https://github.com/KIPPS-AI/n8n-node-kipps-whatsapp-agent/issues"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "cpx": "^1.5.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
